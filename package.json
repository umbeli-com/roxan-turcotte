{
  "name": "roxan-turcotte",
  "version": "0.1.0",
  "private": true,
  "description": "Plateforme web et back-office Roxan Turcotte, Courtier Immobilier",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:client dev:server",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build",
    "build:client": "npm --workspace client run build",
    "build:server": "npm --workspace server run build",
    "start": "npm --workspace server run start",
    "seed": "npm --workspace server run seed",
    "migrate": "npm --workspace server run migrate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
