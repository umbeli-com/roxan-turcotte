# Application
NODE_ENV=development
PORT=3010
PUBLIC_SITE_URL=https://turcotte.umbeli.com

# Base de donnees SQLite (chemin relatif au dossier server)
DATABASE_PATH=./data/roxan.sqlite

# Session / authentification back-office
SESSION_SECRET=remplacez-moi-par-une-chaine-aleatoire-longue
COOKIE_SECURE=false

# Connecteur courriel (transport SMTP, compatible Outlook / Microsoft 365)
MAIL_TRANSPORT=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=roxan@example.com
MAIL_PASSWORD=
MAIL_FROM=Roxan Turcotte <roxan@example.com>
MAIL_NOTIF_INTERNAL_TO=roxan@example.com

# Domaine public (pour les courriels et liens absolus)
PUBLIC_BASE_URL=https://turcotte.umbeli.com

# Anti-pourriel
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
